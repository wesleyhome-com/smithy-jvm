{
  "version": "2.0",
  "projections": {
    "model_only": {
      "plugins": {
        "java-model": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.model",
          "dtoSuffix": ""
        }
      }
    },
    "client_jackson_jdk": {
      "plugins": {
        "java-client": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.client.jackson",
          "dtoSuffix": "DTO",
          "serializationLibrary": "jackson",
          "httpClientLibrary": "jdk"
        }
      }
    },
    "client_gson_jdk": {
      "plugins": {
        "java-client": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.client.gson",
          "dtoSuffix": "DTO",
          "serializationLibrary": "gson",
          "httpClientLibrary": "jdk"
        }
      }
    },
    "client_bare": {
      "plugins": {
        "java-client": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.client.bare",
          "dtoSuffix": "DTO",
          "serializationLibrary": "none",
          "httpClientLibrary": "none"
        }
      }
    },
    "client_okhttp_jackson": {
      "plugins": {
        "java-client": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.client.okhttp",
          "dtoSuffix": "DTO",
          "serializationLibrary": "jackson",
          "httpClientLibrary": "okhttp"
        }
      }
    },
    "full_server": {
      "plugins": {
        "java-spring-server": {
          "service": "com.wesleyhome.library#LibraryService",
          "package": "com.wesleyhome.library.server"
        }
      }
    }
  }
}
